  "resultDetails": {
    "grade_a": {
      "name": "<strong style=\"color:#2C251C; text-align:center; -webkit-text-stroke-width:0.5px; -webkit-text-stroke-color:#2C251C; font-family:'Shilla_Culture(B)'; font-size:60px; font-style:normal; font-weight:700; line-height:100%;\">100점 / A+</strong><p style=\"color:#2C251C; text-align:center; font-family:'Shilla_Culture(B)'; font-size:24px; font-style:normal; font-weight:500; line-height:110%; margin-top: 5px;\">깨달음의 끝, 스터디계의 부처</p>",
      "title": "깨달음의 끝, 스터디계의 부처",
      "description": "<div style=\"text-align:center; margin-bottom:12px;\"><span style=\"display:inline-block; background-color:#2C251C; color:#fff; font-size:12px; font-weight:700; padding:6px 14px; border-radius:999px;\">운세</span></div><div style=\"font-size:14px; font-weight:400; text-align:center; color:#2C251C; line-height:1.4; margin-bottom:32px;\">이번 중간고사, 우주의 기운이<br/>당신의 찍기 실력과 암기력을 돕습니다!</div><div style=\"text-align:center; margin-bottom:12px;\"><span style=\"display:inline-block; background-color:#2C251C; color:#fff; font-size:12px; font-weight:700; padding:6px 14px; border-radius:999px;\">특징</span></div><div style=\"font-size:14px; font-weight:400; text-align:center; color:#2C251C; line-height:1.4; margin-bottom:32px;\">유혹에 흔들리지 않는 에이스.<br/>남들이 유튜브 알고리즘에 빠져 허우적댈 때<br/>묵묵히 진도를 빼는 멘탈 갑입니다.<br/>당신은 이미 모든 걸 깨닫고 통달한 상태.<br/>당신의 펜이 향하는 곳이 곧 정답이니 <br/>자신감을 가지세요!</div><div style=\"text-align:center; margin-bottom:12px;\"><span style=\"display:inline-block; background-color:#2C251C; color:#fff; font-size:12px; font-weight:700; padding:6px 14px; border-radius:999px;\">행운의 아이템</span></div><div style=\"font-size:14px; font-weight:400; text-align:center; color:#2C251C; line-height:1.4; margin-bottom:32px;\">잉크가 절대 마르지 않는 영원의 검은색 볼펜</div>",
      "image": "/images/quiz/mid-term/result_grade_a.png",
      "keywords": [
        "수제자",
        "에이스",
        "멘탈갑"
      ],
      "type": "grade_a"
    },
    "grade_b": {
      "name": "<strong style=\"color:#2C251C; text-align:center; -webkit-text-stroke-width:0.5px; -webkit-text-stroke-color:#2C251C; font-family:'Shilla_Culture(B)'; font-size:60px; font-style:normal; font-weight:700; line-height:100%;\">90점 / B+</strong><p style=\"color:#2C251C; text-align:center; font-family:'Shilla_Culture(B)'; font-size:24px; font-style:normal; font-weight:500; line-height:110%; margin-top: 5px;\">벼락치기계의 닥터 스트레인지</p>",
      "title": "벼락치기계의 닥터 스트레인지",
      "description": "<div style=\"text-align:center; margin-bottom:12px;\"><span style=\"display:inline-block; background-color:#2C251C; color:#fff; font-size:12px; font-weight:700; padding:6px 14px; border-radius:999px;\">운세</span></div><div style=\"font-size:14px; font-weight:400; text-align:center; color:#2C251C; line-height:1.4; margin-bottom:32px;\">효율의 끝판왕!<br/>모든 경우의 수를 계산한 뒤<br/>최소한의 시간으로<br/>최대한의 점수를 뽑아냅니다.</div><div style=\"text-align:center; margin-bottom:12px;\"><span style=\"display:inline-block; background-color:#2C251C; color:#fff; font-size:12px; font-weight:700; padding:6px 14px; border-radius:999px;\">특징</span></div><div style=\"font-size:14px; font-weight:400; text-align:center; color:#2C251C; line-height:1.4; margin-bottom:32px;\">평소엔 놀다가 발등에 불이 떨어져야<br/>초인적인 힘을 발휘하는 타입.<br/><br/>기출문제의 흐름을 읽는 눈치와<br/>찍기 신공이 발동해 예상보다 높은 점수를<br/>얻을 운세입니다.<br/><br/>이미 모든 정답 확률을 계산 끝냈습니다.<br/>최소한의 노력으로 최대의 결과를 얻는,<br/>진정한 '효율의 지배자'입니다.</div><div style=\"text-align:center; margin-bottom:12px;\"><span style=\"display:inline-block; background-color:#2C251C; color:#fff; font-size:12px; font-weight:700; padding:6px 14px; border-radius:999px;\">행운의 아이템</span></div><div style=\"font-size:14px; font-weight:400; text-align:center; color:#2C251C; line-height:1.4; margin-bottom:32px;\">시험 직전 5분 요약본</div>",
      "image": "/images/quiz/mid-term/result_grade_b.png",
      "keywords": [
        "벼락치기",
        "효율끝판왕",
        "눈치코치"
      ],
      "type": "grade_b"
    },
    "grade_c": {
      "name": "<strong style=\"color:#2C251C; text-align:center; -webkit-text-stroke-width:0.5px; -webkit-text-stroke-color:#2C251C; font-family:'Shilla_Culture(B)'; font-size:60px; font-style:normal; font-weight:700; line-height:100%;\">75점 / C+</strong><p style=\"color:#2C251C; text-align:center; font-family:'Shilla_Culture(B)'; font-size:24px; font-style:normal; font-weight:500; line-height:110%; margin-top: 5px;\">학점 외줄 타기 장인:<br/>아슬아슬 중도의 길</p>",
      "title": "학점 외줄 타기 장인:\n아슬아슬 중도의 길",
      "description": "<div style=\"text-align:center; margin-bottom:12px;\"><span style=\"display:inline-block; background-color:#2C251C; color:#fff; font-size:12px; font-weight:700; padding:6px 14px; border-radius:999px;\">운세</span></div><div style=\"font-size:14px; font-weight:400; text-align:center; color:#2C251C; line-height:1.4; margin-bottom:32px;\">재수강, 그 절묘한 경계선 위에서<br/>아슬아슬하게 균형을 잡는<br/>적당히 놀고 적당히 타협하는<br/>평화주의자.</div><div style=\"text-align:center; margin-bottom:12px;\"><span style=\"display:inline-block; background-color:#2C251C; color:#fff; font-size:12px; font-weight:700; padding:6px 14px; border-radius:999px;\">특징</span></div><div style=\"font-size:14px; font-weight:400; text-align:center; color:#2C251C; line-height:1.4; margin-bottom:32px;\">공부도 중요하지만<br/>내 삶의 워라밸도 중요합니다.<br/>남들 맞는 만큼 맞고,<br/>틀리는 건 같이 틀려주는 것이 중도.<br/>평균이라는 중도의 길을<br/>아슬아슬하게 타는 당신은 능력자.</div><div style=\"text-align:center; margin-bottom:12px;\"><span style=\"display:inline-block; background-color:#2C251C; color:#fff; font-size:12px; font-weight:700; padding:6px 14px; border-radius:999px;\">행운의 아이템</span></div><div style=\"font-size:14px; font-weight:400; text-align:center; color:#2C251C; line-height:1.4; margin-bottom:32px;\">아슬아슬하게 충전된 보조배터리</div>",
      "image": "/images/quiz/mid-term/result_grade_c.png",
      "keywords": [
        "평화주의자",
        "워라밸",
        "낭만러"
      ],
      "type": "grade_c"
    },
    "grade_d": {
      "name": "<strong style=\"color:#2C251C; text-align:center; -webkit-text-stroke-width:0.5px; -webkit-text-stroke-color:#2C251C; font-family:'Shilla_Culture(B)'; font-size:60px; font-style:normal; font-weight:700; line-height:100%;\">65점 / D+</strong><p style=\"color:#2C251C; text-align:center; font-family:'Shilla_Culture(B)'; font-size:24px; font-style:normal; font-weight:500; line-height:110%; margin-top: 5px;\">깔아주기 요정!<br/>자비로운 기부천사</p>",
      "title": "깔아주기 요정!\n자비로운 기부천사",
      "description": "<div style=\"text-align:center; margin-bottom:12px;\"><span style=\"display:inline-block; background-color:#2C251C; color:#fff; font-size:12px; font-weight:700; padding:6px 14px; border-radius:999px;\">운세</span></div><div style=\"font-size:14px; font-weight:400; text-align:center; color:#2C251C; line-height:1.4; margin-bottom:32px;\">친구들의 등급 상승을 위해<br/>내 점수를 희생하는<br/>성스러운 운세입니다.</div><div style=\"text-align:center; margin-bottom:12px;\"><span style=\"display:inline-block; background-color:#2C251C; color:#fff; font-size:12px; font-weight:700; padding:6px 14px; border-radius:999px;\">특징</span></div><div style=\"font-size:14px; font-weight:400; text-align:center; color:#2C251C; line-height:1.4; margin-bottom:32px;\">책을 펴면 잠이 오고, 폰을 켜면 눈이 맑아집니다.<br/>이번 시험은 이미 마음속에서<br/>떠나보냈을지도 모릅니다.<br/>그래도 괜찮아요.<br/>친구들은 당신에게 고마워할 거고<br/>다음 시험이 있으니까요!<br/>(아마도)</div><div style=\"text-align:center; margin-bottom:12px;\"><span style=\"display:inline-block; background-color:#2C251C; color:#fff; font-size:12px; font-weight:700; padding:6px 14px; border-radius:999px;\">행운의 아이템</span></div><div style=\"font-size:14px; font-weight:400; text-align:center; color:#2C251C; line-height:1.4; margin-bottom:32px;\">편안한 수면바지</div>",
      "image": "/images/quiz/mid-term/result_grade_d.png",
      "keywords": [
        "기부천사",
        "깔아주기",
        "기말노림"
      ],
      "type": "grade_d"
    },
    "grade_f": {
      "name": "<strong style=\"color:#2C251C; text-align:center; -webkit-text-stroke-width:0.5px; -webkit-text-stroke-color:#2C251C; font-family:'Shilla_Culture(B)'; font-size:60px; font-style:normal; font-weight:700; line-height:100%;\">50점 / F</strong><p style=\"color:#2C251C; text-align:center; font-family:'Shilla_Culture(B)'; font-size:24px; font-style:normal; font-weight:500; line-height:110%; margin-top: 5px;\">성적:<br/>404 Not found</p>",
      "title": "성적:\n404 Not found",
      "description": "<div style=\"text-align:center; margin-bottom:12px;\"><span style=\"display:inline-block; background-color:#2C251C; color:#fff; font-size:12px; font-weight:700; padding:6px 14px; border-radius:999px;\">운세</span></div><div style=\"font-size:14px; font-weight:400; text-align:center; color:#2C251C; line-height:1.4; margin-bottom:32px;\">벼락치기요?<br/>아니요, 당신은 그냥 '벼락'을 맞았습니다.</div><div style=\"text-align:center; margin-bottom:12px;\"><span style=\"display:inline-block; background-color:#2C251C; color:#fff; font-size:12px; font-weight:700; padding:6px 14px; border-radius:999px;\">특징</span></div><div style=\"font-size:14px; font-weight:400; text-align:center; color:#2C251C; line-height:1.4; margin-bottom:32px;\">마침 밖엔 꽃이 폈고<br/>봄바람이 기분좋게 부는데,<br/>성적이 뭐가 중요하겠습니까?<br/><br/>조용히 답안지를 덮으며<br/>그 어떤 미련도 없이<br/>시원하게 성적을 놓아주는<br/>마음가짐도 가끔 필요합니다.</div><div style=\"text-align:center; margin-bottom:12px;\"><span style=\"display:inline-block; background-color:#2C251C; color:#fff; font-size:12px; font-weight:700; padding:6px 14px; border-radius:999px;\">행운의 아이템</span></div><div style=\"font-size:14px; font-weight:400; text-align:center; color:#2C251C; line-height:1.4; margin-bottom:32px;\">벚꽃 한 송이</div>",
      "image": "/images/quiz/mid-term/result_grade_f.png",
      "keywords": [
        "무소유",
        "순백의뇌",
        "마이너스손"
      ],
      "type": "grade_f"
    }
