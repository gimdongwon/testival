    "aje_fatal": {
      "name": "중증형",
      "title": "치명적 아재 파탈\n(중증)",
      "personalitySectionTitle": "성격 특징",
      "description": "가슴에 하트 로고 박힌 가디건을 입고\n한정판 조던을 신으며\n「나 정도면 관리 잘한 편이지.」라고\n굳게 믿고 계시는군요.\n\n대화할 때마다 「오빠가~」를 남발하며\nMZ 후배들과 완벽하게 통한다고 착각하지만,\n현실은 2030 여성들에게\n눈빛으로 경멸 당하고 있습니다.\n\n비싼 아이템으로 포장해도 숨겨지지 않는\n그 「치명적인 척」,\n당장 압수입니다!<div style=\"display:flex;flex-direction:column;align-items:center;gap:20px;width:100%;margin-top:20px\"><div style=\"display:flex;flex-direction:column;align-items:center;gap:4px;width:100%\"><span style=\"display:inline-flex;align-items:center;justify-content:center;background:#d9dee3;border:1px solid #46618a;border-radius:74px;padding:2px 22px;font-family:'Noto Sans KR',sans-serif;font-size:14px;font-weight:400;color:#111e32\">환상의 짝꿍</span><p style=\"margin:0;width:100%;max-width:280px;text-align:center;font-family:'Noto Sans KR',sans-serif;font-size:14px;line-height:1.2;color:#111e32;word-break:keep-all\">으~! 영포티다 으~</p></div><div style=\"display:flex;flex-direction:column;align-items:center;gap:4px;width:100%\"><span style=\"display:inline-flex;align-items:center;justify-content:center;background:#efc7b6;border:1px solid #db7b53;border-radius:74px;padding:2px 22px;font-family:'Noto Sans KR',sans-serif;font-size:14px;font-weight:400;color:#111e32\">파국의 짝꿍</span><p style=\"margin:0;width:100%;max-width:280px;text-align:center;font-family:'Noto Sans KR',sans-serif;font-size:14px;line-height:1.2;color:#111e32;word-break:keep-all\">훌륭한 신사(gentleman)</p></div></div>",
      "keywords": [
        "착각",
        "오빠 미학",
        "과시",
        "중증"
      ],
      "type": "aje_fatal",
      "image": "/images/quiz/young40/result_aje_fatal.png"
    },
    "young40_peak": {
      "name": "영포티 끝판왕",
      "title": "으~!\n영포티다 으~",
      "personalitySectionTitle": "성격 특징",
      "description": "구제불능 영포티 그 자체입니다. 눈치 제로, 자아도취 MAX 상태일 수 있어요.\n\n20대도 안 쓰는 철 지난 유행어를 남발하며 젊은 여성들에게 통할 거라 굳게 믿고 있다면, 주변인들이 심각하게 피로감을 느낄 수 있습니다.\n\n셔츠 단추와 억지 플러팅, 한번쯤 리셋이 필요해 보입니다.<div style=\"display:flex;flex-direction:column;align-items:center;gap:20px;width:100%;margin-top:20px\"><div style=\"display:flex;flex-direction:column;align-items:center;gap:4px;width:100%\"><span style=\"display:inline-flex;align-items:center;justify-content:center;background:#d9dee3;border:1px solid #46618a;border-radius:74px;padding:2px 22px;font-family:'Noto Sans KR',sans-serif;font-size:14px;font-weight:400;color:#111e32\">환상의 짝꿍</span><p style=\"margin:0;width:100%;max-width:280px;text-align:center;font-family:'Noto Sans KR',sans-serif;font-size:14px;line-height:1.2;color:#111e32;word-break:keep-all\">치명적 아재 파탈 (중증)</p></div><div style=\"display:flex;flex-direction:column;align-items:center;gap:4px;width:100%\"><span style=\"display:inline-flex;align-items:center;justify-content:center;background:#efc7b6;border:1px solid #db7b53;border-radius:74px;padding:2px 22px;font-family:'Noto Sans KR',sans-serif;font-size:14px;font-weight:400;color:#111e32\">파국의 짝꿍</span><p style=\"margin:0;width:100%;max-width:280px;text-align:center;font-family:'Noto Sans KR',sans-serif;font-size:14px;line-height:1.2;color:#111e32;word-break:keep-all\">훌륭한 신사(gentleman)</p></div></div>",
      "keywords": [
        "구제불능",
        "유행어",
        "자아도취",
        "눈치 제로"
      ],
      "type": "young40_peak",
      "image": "/images/quiz/young40/result_young40_peak.png"
    }
